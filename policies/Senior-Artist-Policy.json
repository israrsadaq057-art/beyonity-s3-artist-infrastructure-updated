{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": ["s3:ListBucket", "s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
            "Resource": [
                "arn:aws:s3:::beyonity-3d-assets-prod-945504685795",
                "arn:aws:s3:::beyonity-3d-assets-prod-945504685795/artists/${aws:username}/*",
                "arn:aws:s3:::beyonity-3d-assets-prod-945504685795/shared/*",
                "arn:aws:s3:::beyonity-3d-assets-prod-945504685795/projects/*/Team-Shared/*",
                "arn:aws:s3:::beyonity-3d-assets-prod-945504685795/projects/*/Team-Lead-Only/*"
            ]
        },
        {
            "Effect": "Allow",
            "Action": ["ec2:DescribeInstances", "ec2:StartInstances", "ec2:StopInstances"],
            "Resource": "*"
        }
    ]
}
